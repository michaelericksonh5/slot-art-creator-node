# Copy this file to .env and fill in your key(s).
# Run `node setup-keys.js` to do this interactively.
#
# Provider priority (when both keys are set):
#   nb2_generate / nb2_edit / nb2_upscale → Gemini (preferred)
#   nb2_smart_resize                       → fal.ai (required — no Gemini equivalent)
#
# RECOMMENDED — Google AI Studio / Gemini (preferred for generate / edit / upscale)
#   Get a key at https://aistudio.google.com/apikey
#   Run:  node setup-keys.js --gemini
GEMINI_API_KEY=
#
# REQUIRED for smart-resize, fallback for generate / edit / upscale — fal.ai
#   Get a key at https://fal.ai/dashboard
#   Run:  node setup-keys.js --fal
FAL_KEY=
#
# At least one key is required.
# For full functionality (all 4 tools), set BOTH keys.
# Gemini-only is fine if you don't need smart-resize.
